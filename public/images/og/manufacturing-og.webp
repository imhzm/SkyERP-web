<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#0a0a0a"/>
      <stop offset="100%" stop-color="#001A3A"/>
    </linearGradient>
    <linearGradient id="accent" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#0A6CF1"/>
      <stop offset="50%" stop-color="#8B2CF5"/>
      <stop offset="100%" stop-color="#FF4FD8"/>
    </linearGradient>
  </defs>
  <rect width="1200" height="630" fill="url(#bg)"/>
  <line x1="200" y1="0" x2="200" y2="630" stroke="rgba(10,108,241,0.05)" stroke-width="1"/>
  <line x1="400" y1="0" x2="400" y2="630" stroke="rgba(10,108,241,0.05)" stroke-width="1"/>
  <line x1="600" y1="0" x2="600" y2="630" stroke="rgba(10,108,241,0.05)" stroke-width="1"/>
  <line x1="800" y1="0" x2="800" y2="630" stroke="rgba(10,108,241,0.05)" stroke-width="1"/>
  <line x1="1000" y1="0" x2="1000" y2="630" stroke="rgba(10,108,241,0.05)" stroke-width="1"/>
  <line x1="0" y1="200" x2="1200" y2="200" stroke="rgba(10,108,241,0.05)" stroke-width="1"/>
  <line x1="0" y1="400" x2="1200" y2="400" stroke="rgba(10,108,241,0.05)" stroke-width="1"/>
  <text x="40" y="60" font-family="Arial, sans-serif" font-size="24" fill="#0A6CF1" font-weight="bold">Sky ERP</text>
  <circle cx="900" cy="200" r="180" fill="none" stroke="url(#accent)" stroke-width="2" opacity="0.15"/>
  <circle cx="900" cy="200" r="250" fill="none" stroke="url(#accent)" stroke-width="1" opacity="0.08"/>
  <text x="600" y="310" font-family="Arial, sans-serif" font-size="52" fill="#FFFFFF" text-anchor="middle" font-weight="bold">نظام التصنيع</text>
  <text x="600" y="380" font-family="Arial, sans-serif" font-size="22" fill="#888899" text-anchor="middle">نظام ERP ذكي لإدارة الشركات</text>
  <rect x="530" y="420" width="140" height="3" rx="1.5" fill="url(#accent)"/>
</svg>